#!/bin/bash

COMPOSE_FILE="${COMPOSE_FILE:-docker-compose.yml}"
echo "Using compose file: $COMPOSE_FILE"
# Start services
start() {
    echo "Building and starting services..."
    docker compose -f $COMPOSE_FILE up --build --force-recreate -d
    echo "Cleaning up dangling images..."
    docker image prune -f
    echo "Done! Services are running."
    echo "Showing logs (Ctrl+C to exit, services keep running)..."
    logs
}

# Stop services
down() {
    echo "Stopping services..."
    docker compose -f $COMPOSE_FILE down -v
}

# View logs
logs() {
    if [ -z "$1" ]; then
        # All logs
        docker compose -f $COMPOSE_FILE logs -f
    else
        # Specific service logs
        docker compose -f $COMPOSE_FILE logs --tail 500 "$1"
    fi
}

logsf() {
    # All logs
    docker compose -f $COMPOSE_FILE logs -f "$1"
}

# Restart service
restart() {
    if [ -z "$1" ]; then
        echo "Error: Please specify service name"
        echo "Usage: ./scripts restart <service>"
        echo "Services: stt, tts, gateway, auth, webapp, mongo"
        exit 1
    fi
    echo "Restarting $1..."
    docker compose -f $COMPOSE_FILE restart "$1"
}

# Rebuild service
rebuild() {
    if [ -z "$1" ]; then
        echo "Error: Please specify service name"
        echo "Usage: ./scripts rebuild <service>"
        echo "Services: stt, tts, gateway, auth, webapp"
        exit 1
    fi
    echo "Rebuilding $1..."
    docker compose -f $COMPOSE_FILE up -d --build --force-recreate "$1"
    echo "Cleaning up dangling images..."
    docker image prune -f
}

# Install client components (CLI + VS Code extension) — run on the machine you code on
install-client() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    echo "==> Installing CLI dependencies..."
    cd "$SCRIPT_DIR/cli" && npm install
    echo "    ✓ CLI ready"

    echo ""
    echo "==> Building VS Code extension..."
    cd "$SCRIPT_DIR/vscode-extension" && npm install && npm run compile && npx vsce package --no-dependencies
    VSIX=$(ls "$SCRIPT_DIR/vscode-extension"/*.vsix | head -1)
    echo "    Installing extension..."
    code --install-extension "$VSIX"
    echo "    ✓ VS Code extension installed"

    echo ""
    echo "All done!"
    echo "Run 'pair' from any directory to start."
    echo "If your LLM server is on a remote machine, set the URL via /settings > Local Server URL."
}

# Install server components (llama.cpp Docker image) — run on the machine hosting the model
install-server() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    GGUF="$SCRIPT_DIR/llamacpp/models/qwen3-coder-next-q4_k_m.gguf"

    echo "==> Checking for model..."
    if [ ! -f "$GGUF" ]; then
        echo ""
        echo "ERROR: Model not found at:"
        echo "  $GGUF"
        echo ""
        echo "To get the model, either:"
        echo "  1. Download Qwen3-Coder-Next safetensors into models/qwen3-coder-next/"
        echo "     then run: ./llamacpp/quantize.sh"
        echo ""
        echo "  2. Download a pre-quantized GGUF and place it at:"
        echo "     $GGUF"
        echo ""
        exit 1
    fi
    echo "    ✓ Model found"

    echo ""
    echo "==> Building Docker image..."
    cd "$SCRIPT_DIR" && docker compose build
    echo "    ✓ Docker image built"

    echo ""
    echo "All done! Run './scripts run-server' to start the LLM server."
}

# Start the LLM server (run on the server machine)
run-server() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    echo "==> Starting LLM server..."
    cd "$SCRIPT_DIR" && docker compose up -d
    echo "    ✓ LLM server running on port 8004"
}

# Show help
help() {
    echo "Available commands:"
    echo "  install-client   - Install CLI globally + VS Code extension (run on your coding machine)"
    echo "  install-server   - Check model and build Docker image (run on the machine hosting the model)"
    echo "  run-server       - Start the LLM server via Docker"
    echo "  start            - Build and start all services"
    echo "  down             - Stop all services"
    echo "  logs [service]   - View logs (all or specific service)"
    echo "  restart <service> - Restart a specific service"
    echo "  rebuild <service> - Rebuild a specific service"
    echo "  setup            - Setup environment (download models, etc.)"
    echo "  npminstall       - Install npm dependencies for all components"
    echo ""
    echo "Examples:"
    echo "  ./scripts start"
    echo "  ./scripts logs stt"
    echo "  ./scripts restart gateway"
    echo "  ./scripts rebuild tts"
}

# Main command router
case "$1" in
    install-client)
        install-client
        ;;
    install-server)
        install-server
        ;;
    run-server)
        run-server
        ;;
    start)
        start
        ;;
    down)
        down
        ;;
    logs)
        logs "$2"
        ;;
    logsf)
        logsf "$2"
        ;;
    restart)
        restart "$2"
        ;;
    rebuild)
        rebuild "$2"
        ;;
    dbstate)
        dbstate
        ;;
    help|--help|-h|"")
        help
        ;;
    setup)
        setup
        ;;
    npminstall)
        npminstall
        ;;
    deletelancedbrows)
        deletelancedbrows
        ;;
    migrate-lancedb)
        migrate_lancedb
        ;;
    *)
        echo "Error: Unknown command '$1'"
        help
        exit 1
        ;;
esac
