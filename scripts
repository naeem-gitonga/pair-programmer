#!/bin/bash

COMPOSE_FILE="${COMPOSE_FILE:-docker-compose.yml}"
echo "Using compose file: $COMPOSE_FILE"
# Start services
start() {
    echo "Building and starting services..."
    docker compose -f $COMPOSE_FILE up --build --force-recreate -d
    echo "Cleaning up dangling images..."
    docker image prune -f
    echo "Done! Services are running."
    echo "Showing logs (Ctrl+C to exit, services keep running)..."
    logs
}

# Stop services
down() {
    echo "Stopping services..."
    docker compose -f $COMPOSE_FILE down -v
}

# View logs
logs() {
    if [ -z "$1" ]; then
        # All logs
        docker compose -f $COMPOSE_FILE logs -f
    else
        # Specific service logs
        docker compose -f $COMPOSE_FILE logs --tail 500 "$1"
    fi
}

logsf() {
    # All logs
    docker compose -f $COMPOSE_FILE logs -f "$1"
}

# Restart service
restart() {
    if [ -z "$1" ]; then
        echo "Error: Please specify service name"
        echo "Usage: ./scripts restart <service>"
        echo "Services: llm, smolvlm2"
        exit 1
    fi
    echo "Restarting $1..."
    docker compose -f $COMPOSE_FILE restart "$1"
}

# Rebuild service
rebuild() {
    if [ -z "$1" ]; then
        echo "Error: Please specify service name"
        echo "Usage: ./scripts rebuild <service>"
        echo "Services: llm, smolvlm2"
        exit 1
    fi
    echo "Rebuilding $1..."
    docker compose -f $COMPOSE_FILE up -d --build --force-recreate "$1"
    echo "Cleaning up dangling images..."
    docker image prune -f
}

# Install client components (CLI + VS Code extension) — run on the machine you code on
install-client() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    echo "==> Installing CLI dependencies..."
    cd "$SCRIPT_DIR/cli" && npm install
    echo "    ✓ CLI ready"

    echo ""
    echo "==> Building VS Code extension..."
    cd "$SCRIPT_DIR/vscode-extension" && npm install && npm run compile && npx vsce package --no-dependencies
    VSIX=$(ls "$SCRIPT_DIR/vscode-extension"/*.vsix | head -1)
    echo "    Installing extension..."
    code --install-extension "$VSIX"
    echo "    ✓ VS Code extension installed"

    echo ""
    echo "All done!"
    echo "Run 'pair' from any directory to start."
    echo "If your LLM server is on a remote machine, set the URL via /settings > Local Server URL."
}

# Install server components (llama.cpp + SmolVLM2 Docker images) — run on the machine hosting the models
install-server() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    GGUF="$SCRIPT_DIR/llamacpp/models/qwen3-coder-next-q4_k_m.gguf"
    SMOLVLM_MODELS="$SCRIPT_DIR/vllm/models/smolvlm2"

    echo "==> Checking for models..."
    
    # Check Qwen3 model
    if [ ! -f "$GGUF" ]; then
        echo ""
        echo "ERROR: Qwen3 model not found at:"
        echo "  $GGUF"
        echo ""
        echo "To get the model, either:"
        echo "  1. Download Qwen3-Coder-Next safetensors into models/qwen3-coder-next/"
        echo "     then run: ./llamacpp/quantize.sh"
        echo ""
        echo "  2. Download a pre-quantized GGUF and place it at:"
        echo "     $GGUF"
        echo ""
        exit 1
    fi
    echo "    ✓ Qwen3 model found"

    # Check SmolVLM2 models
    if [ ! -d "$SMOLVLM_MODELS" ] || [ -z "$(ls -A $SMOLVLM_MODELS 2>/dev/null)" ]; then
        echo ""
        echo "WARNING: SmolVLM2 model directory not found or empty at:"
        echo "  $SMOLVLM_MODELS"
        echo ""
        echo "SmolVLM2 is optional. To enable vision capabilities:"
        echo "  1. Download SmolVLM2-500M-Video-Instruct into vllm/models/smolvlm2/"
        echo "     from HuggingFace"
        echo ""
    else
        echo "    ✓ SmolVLM2 model found"
    fi

    echo ""
    echo "==> Building Docker images..."
    cd "$SCRIPT_DIR" && docker compose build
    echo "    ✓ Docker images built"

    echo ""
    echo "All done! Run './scripts run-server' to start the LLM servers."
}

# Start the LLM servers (run on the server machine)
run-server() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    echo "==> Starting LLM servers..."
    cd "$SCRIPT_DIR" && docker compose up -d
    echo "    ✓ Qwen3 server running on port 8004"
    echo "    ✓ SmolVLM2 server running on port 8005"
}

# Start only SmolVLM2 server
run-smolvlm2() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    echo "==> Starting SmolVLM2 server..."
    docker compose -f $COMPOSE_FILE up -d smolvlm2
    echo "    ✓ SmolVLM2 server running on port 8005"
}

# Show help
help() {
    echo "Available commands:"
    echo "  install-client   - Install CLI globally + VS Code extension (run on your coding machine)"
    echo "  install-server   - Check models and build Docker image (run on the machine hosting the models)"
    echo "  run-server       - Start the LLM servers (Qwen3 on 8004, SmolVLM2 on 8005)"
    echo "  run-smolvlm2     - Start only SmolVLM2 server (on port 8005)"
    echo "  start            - Build and start all services"
    echo "  down             - Stop all services"
    echo "  logs [service]   - View logs (all or specific service)"
    echo "  restart <service> - Restart a specific service (llm, smolvlm2)"
    echo "  rebuild <service> - Rebuild a specific service"
    echo ""
    echo "Examples:"
    echo "  ./scripts start"
    echo "  ./scripts logs llm"
    echo "  ./scripts logs smolvlm2"
    echo "  ./scripts restart smolvlm2"
    echo "  ./scripts rebuild llm"
}

# Main command router
case "$1" in
    install-client)
        install-client
        ;;
    install-server)
        install-server
        ;;
    run-server)
        run-server
        ;;
    run-smolvlm2)
        run-smolvlm2
        ;;
    start)
        start
        ;;
    down)
        down
        ;;
    logs)
        logs "$2"
        ;;
    logsf)
        logsf "$2"
        ;;
    restart)
        restart "$2"
        ;;
    rebuild)
        rebuild "$2"
        ;;
    help|--help|-h|"")
        help
        ;;
    *)
        echo "Error: Unknown command '$1'"
        help
        exit 1
        ;;
esac
